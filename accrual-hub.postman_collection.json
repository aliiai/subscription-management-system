            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": {{customer_id}},\n  \"subscription_id\": null,\n  \"issue_date\": \"2026-01-01\",\n  \"due_date\": \"2026-01-15\",\n  \"amount\": 100\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/invoices",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "invoices"]
            },
            "description": "Posts the issuing journal entry automatically: Dr Accounts Receivable / Cr Deferred Revenue."
          }
        },
        {
          "name": "Generate Monthly Invoices",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"month\": \"2026-02\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/invoices/generate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "invoices", "generate"]
            },
            "description": "Cron simulation: creates invoices for all active subscriptions for the given month. Idempotent. `month` is optional (defaults to current month)."
          }
        },
        {
          "name": "Get Invoice",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/invoices/{{invoice_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "invoices", "{{invoice_id}}"]
            },
            "description": "Returns the invoice with its payments and linked journal entries."
          }
        },
        {
          "name": "Void Invoice",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/invoices/{{invoice_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "invoices", "{{invoice_id}}"]
            },
            "description": "Voids an invoice that has no payments and reverses its journal entry. Returns 422 if payments exist."
          }
        }
      ]
    },
