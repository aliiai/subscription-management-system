{
  "info": {
    "name": "Accrual Hub API (v1)",
    "_postman_id": "a1b2c3d4-0001-4a00-9000-accrualhubv1",
    "description": "Professional REST API collection for the Accrual Hub multi-tenant subscription & accounting platform.\n\n## Getting started\n1. Set the `base_url` variable (default: http://127.0.0.1:8000).\n2. Call **Auth > Register** (new company) or **Auth > Login** (existing user). Both requests automatically store the returned token into the `token` collection variable.\n3. All protected requests send `Authorization: Bearer {{token}}` automatically.\n\n## Conventions\n- Versioned under `/api/v1`.\n- Multi-tenant: every request only ever sees the authenticated company's data.\n- List endpoints are paginated and accept `per_page`, plus resource-specific filters.\n- Money values are returned as numbers; dates as ISO strings.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "plan_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "customer_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "subscription_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "invoice_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "payment_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "journal_entry_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "notification_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Registration, login, session and token management.",
      "item": [
        {
          "name": "Register Company",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.token) {",
                  "        pm.collectionVariables.set('token', json.token);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company_name\": \"Acme LLC\",\n  \"company_email\": \"info@acme.test\",\n  \"company_phone\": \"+966500000000\",\n  \"name\": \"Owner Name\",\n  \"email\": \"owner@acme.test\",\n  \"password\": \"Password123!\",\n  \"password_confirmation\": \"Password123!\",\n  \"device_name\": \"postman\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "register"]
            },
            "description": "Provision a new company (tenant) with its first owner user and seed the chart of accounts. Returns a personal access token."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.token) {",
                  "        pm.collectionVariables.set('token', json.token);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@acme.test\",\n  \"password\": \"Password123!\",\n  \"device_name\": \"postman\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "login"]
            },
            "description": "Authenticate by email/password and receive a personal access token."
          }
        },
        {
          "name": "Current User (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "me"]
            },
            "description": "Return the authenticated user and their company."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "logout"]
            },
            "description": "Revoke the access token used for the current request."
          }
        }
      ]
    },
