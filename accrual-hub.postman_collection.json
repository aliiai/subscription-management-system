    {
      "name": "Invoices",
      "description": "Invoicing and automated monthly generation (Cron simulation).",
      "item": [
        {
          "name": "List Invoices",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/invoices?per_page=15&status=&customer=&q=&from=&to=",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "invoices"],
              "query": [
                { "key": "per_page", "value": "15" },
                { "key": "status", "value": "", "description": "unpaid | partially_paid | paid | void" },
                { "key": "customer", "value": "", "description": "Filter by customer id" },
                { "key": "q", "value": "", "description": "Search invoice number / customer name" },
                { "key": "from", "value": "", "description": "Issue date from (YYYY-MM-DD)" },
                { "key": "to", "value": "", "description": "Issue date to (YYYY-MM-DD)" }
              ]
            }
          }
        },
        {
          "name": "Create Invoice",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
